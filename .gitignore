# ── Terraform ────────────────────────────────────────────────────
# Local plugin cache — regenerated by `terraform init`
.terraform/
terraform/**/.terraform/

# State files — contain sensitive values, managed remotely (S3 backend)
*.tfstate
*.tfstate.*

# Secret variable files — never commit credentials
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# ── Node / React ─────────────────────────────────────────────────
node_modules/
lovemap/node_modules/

# Production build artifacts — generated by `npm run build`
build/
lovemap/build/

# ── Secrets ──────────────────────────────────────────────────────
mapbox_token
.env
.env.*

# ── OS / Editor ──────────────────────────────────────────────────
.DS_Store
